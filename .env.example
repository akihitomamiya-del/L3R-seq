# =============================================================================
# L3Rseq Data Mount Configuration
# =============================================================================
#
# Copy this file to .env and replace ALL "EDIT_ME:" values with your paths.
# The pipeline will NOT start until you edit these — "EDIT_ME:" is not a
# valid path and Docker will show a clear error.
#
#   cp .env.example .env
#   nano .env
#
# Then run:
#   docker compose run l3rseq L3Rseq run \
#     --input /data/input --outdir /data/output \
#     --ref /data/input/your_reference.fa --pattern CT
# =============================================================================

# Path to your input FASTQ directory on the host.
# SECURITY: Mounted read-only (:ro) inside the container — the pipeline
# cannot modify or delete your source data. Even root can't bypass this.
# Example: /home/user/data/E201015_1_231203
L3RSEQ_INPUT=EDIT_ME:/home/yourname/data/fastq

# Path where pipeline output will be written on the host.
# WARNING: Mounted read-write — the pipeline (and Claude Code, if running
# inside the devcontainer) can read, write, and delete files here.
# Use a dedicated empty directory, not your home folder or existing data.
# Example: /home/user/results/experiment1
L3RSEQ_OUTPUT=EDIT_ME:/home/yourname/results

# Your host user UID and GID — ensures output files are owned by you.
# Run these commands to find your values:
#   id -u    (prints UID, e.g. 1000)
#   id -g    (prints GID, e.g. 1000)
L3RSEQ_UID=EDIT_ME
L3RSEQ_GID=EDIT_ME

# IGV viewer port (optional, default 8080)
L3RSEQ_PORT=8080
