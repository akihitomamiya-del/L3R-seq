{
  "name": "L3Rseq Pipeline (build)",
  "build": {
    "dockerfile": "Dockerfile",
    "context": "../.."
  },
  "features": {
    "ghcr.io/devcontainers/features/github-cli:1": {}
  },
  "customizations": {
    "vscode": {
      // Mermaid renders natively via VS Code's built-in
      // mermaid-markdown-features; a third-party mermaid extension here would
      // double-register and break diagram rendering in the Markdown preview.
      "settings": {
        "terminal.integrated.defaultProfile.linux": "zsh"
      }
    }
  },
  "forwardPorts": [8080],
  "portsAttributes": {
    "8080": { "label": "IGV Viewer", "onAutoForward": "notify" }
  },
  "remoteUser": "vscode",
  "updateRemoteUserUID": true,
  "workspaceMount": "source=${localWorkspaceFolder},target=/workspace,type=bind,consistency=delegated",
  "workspaceFolder": "/workspace",
  "mounts": [
    "source=l3rseq-runs,target=/runs,type=volume"
  ],
  "remoteEnv": {
    "TMPDIR": "/runs/.tmp"
  },
  "postCreateCommand": "cd /workspace/igv_viewer && npm install --silent && sudo chown -R vscode:vscode /runs && mkdir -p /runs/.tmp && (test -L /workspace/runs || (test -d /workspace/runs && mv /workspace/runs /workspace/runs.bind-old || true; ln -s /runs /workspace/runs))",
  "postStartCommand": "setsid -f node /workspace/igv_viewer/server.js > /tmp/igv-server.log 2>&1"
}
