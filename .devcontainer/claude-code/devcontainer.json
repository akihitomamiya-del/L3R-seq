{
  "name": "L3Rseq Pipeline (Claude Code Sandbox)",
  "build": {
    "dockerfile": "Dockerfile",
    "context": "../..",
    "args": {
      "TZ": "${localEnv:TZ:UTC}",
      "CLAUDE_CODE_VERSION": "latest",
      "GIT_DELTA_VERSION": "0.18.2",
      "ZSH_IN_DOCKER_VERSION": "1.2.0"
    }
  },
  "runArgs": [
    "--cap-add=NET_ADMIN",
    "--cap-add=NET_RAW"
  ],
  "features": {
    "ghcr.io/devcontainers/features/github-cli:1": {}
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "GitHub.codespaces",
        "anthropic.claude-code",
        "eamodio.gitlens",
        "bierner.markdown-mermaid",
        "mechatroner.rainbow-csv"
      ],
      "settings": {
        "terminal.integrated.defaultProfile.linux": "zsh"
      }
    }
  },
  "remoteUser": "vscode",
  "updateRemoteUserUID": true,
  "mounts": [
    "source=claude-code-bashhistory-${devcontainerId},target=/commandhistory,type=volume",
    "source=claude-code-config-${devcontainerId},target=/home/vscode/.claude,type=volume"
  ],
  "containerEnv": {
    "NODE_OPTIONS": "--max-old-space-size=4096",
    "CLAUDE_CONFIG_DIR": "/home/vscode/.claude",
    "POWERLEVEL9K_DISABLE_GITSTATUS": "true",
    "IGV_DATA_DIR": "/data/output",
    "PUPPETEER_SKIP_DOWNLOAD": "true"
  },
  "remoteEnv": {
    "ANTHROPIC_API_KEY": "${localEnv:ANTHROPIC_API_KEY}",
    "CLAUDE_CODE_OAUTH_TOKEN": "${localEnv:CLAUDE_CODE_OAUTH_TOKEN}"
  },
  "workspaceMount": "source=${localWorkspaceFolder},target=/workspace,type=bind,consistency=delegated",
  "workspaceFolder": "/workspace",
  "forwardPorts": [8080],
  "portsAttributes": {
    "8080": { "label": "IGV Viewer", "onAutoForward": "notify" }
  },
  "postCreateCommand": "mkdir -p ~/.claude && cp /workspace/.devcontainer/claude-code/CLAUDE.md ~/.claude/CLAUDE.md && cd /workspace/igv_viewer && npm install",
  "postStartCommand": {
    "firewall": "sudo /usr/local/bin/start-firewall.sh",
    "igv-viewer": "node /workspace/igv_viewer/server.js > /tmp/igv-server.log 2>&1 &"
  },
  "waitFor": "postStartCommand"
}
