# Exclude everything, then include only what the Dockerfiles need.
# Mirrors the allowlist pattern in .gitignore.
*

# Build dependencies (COPYed by Dockerfile)
# Only include build/ — default/ and claude-code/ are not needed by the main image
!.devcontainer/build/
!.devcontainer/build/**
!.devcontainer/claude-code/
!.devcontainer/claude-code/**
!longread_umi_L3Rseq/
!longread_umi_L3Rseq/**
!UMIC-seq_L3Rseq/
!UMIC-seq_L3Rseq/**

# Pipeline runtime code
!L3Rseq
!config.sh
!scripts/
!scripts/**
!resources/
!resources/**
!igv_viewer/
!igv_viewer/**
igv_viewer/node_modules/
