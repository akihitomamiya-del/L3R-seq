# Default: auto-detect text vs binary per file, and normalize text files to
# LF on checkout regardless of host OS. This overrides Git-for-Windows'
# default core.autocrlf=true, so a fresh clone on Windows produces the same
# working tree as a clone on Linux/macOS — no phantom `git status` diffs,
# no broken shebangs, no CRLF drift. All the explicit rules below are now
# redundant with this catch-all but are kept because their comments document
# WHY specific file classes must stay LF (critical for reviewers).
* text=auto eol=lf

# Force LF line endings for files the Linux container and pipeline execute.
# Without this, Windows checkouts with core.autocrlf=true get CRLF shebangs,
# which causes "No such file or directory" errors when Linux tries to exec
# the interpreter.
*.sh         text eol=lf
L3Rseq       text eol=lf
l3rseq-docker text eol=lf
Snakefile    text eol=lf

# FASTA and FAI must stay LF too — samtools-generated .fai byte offsets
# are computed against the .fasta's exact byte layout, so CRLF drift on
# the host would invalidate the index.
*.fasta      text eol=lf
*.fa         text eol=lf
*.fai        text eol=lf

# Test data and expected outputs are compared byte-for-byte and parsed by
# tools that treat CR as whitespace or as a line separator (Python's
# universal newlines, bash string equality). CRLF drift on Windows hosts
# causes spurious test failures — force LF for all text-format data files.
*.txt        text eol=lf
*.tsv        text eol=lf
*.csv        text eol=lf
*.bed        text eol=lf
*.gff        text eol=lf
*.gff3       text eol=lf
*.yaml       text eol=lf
*.yml        text eol=lf
*.py         text eol=lf
*.js         text eol=lf

# Explicit binary markers. The `* text=auto` default would usually detect
# these correctly, but being explicit protects against edge cases (e.g. a
# small BAM whose first bytes happen to look like ASCII, or a BLAST DB
# shard that lacks NUL bytes early). Once tagged `binary`, Git never
# attempts EOL filtering, content merging, or textconv on these files.
*.bam        binary
*.bai        binary
*.gz         binary
*.zip        binary
*.tar        binary
*.png        binary
*.jpg        binary
*.jpeg       binary
*.ico        binary
*.pdf        binary
# BLAST database shards (nucleotide indexes)
*.nhr        binary
*.nin        binary
*.nsq        binary
*.ndb        binary
*.ntf        binary
*.nto        binary
*.not        binary
*.nog        binary
*.nos        binary
*.nhd        binary
