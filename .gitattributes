# Force LF line endings for files the Linux container and pipeline execute.
# Without this, Windows checkouts with core.autocrlf=true get CRLF shebangs,
# which causes "No such file or directory" errors when Linux tries to exec
# the interpreter.
*.sh         text eol=lf
L3Rseq       text eol=lf
l3rseq-docker text eol=lf
Snakefile    text eol=lf

# FASTA and FAI must stay LF too — samtools-generated .fai byte offsets
# are computed against the .fasta's exact byte layout, so CRLF drift on
# the host would invalidate the index.
*.fasta      text eol=lf
*.fa         text eol=lf
*.fai        text eol=lf

# Test data and expected outputs are compared byte-for-byte and parsed by
# tools that treat CR as whitespace or as a line separator (Python's
# universal newlines, bash string equality). CRLF drift on Windows hosts
# causes spurious test failures — force LF for all text-format data files.
*.txt        text eol=lf
*.tsv        text eol=lf
*.csv        text eol=lf
*.bed        text eol=lf
*.gff        text eol=lf
*.gff3       text eol=lf
*.yaml       text eol=lf
*.yml        text eol=lf
*.py         text eol=lf
*.js         text eol=lf
