# Usage: L3Rseq <subcommand> [options]
# See: L3Rseq --help

set -euo pipefail

# ---------------------------------------------------------------------------
# Resolve script locations
# ---------------------------------------------------------------------------
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
