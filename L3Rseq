# ---------------------------------------------------------------------------
# Initialize conda (required for tool activation)
# ---------------------------------------------------------------------------
if ! eval "$(conda shell.bash hook)" 2>/dev/null; then
    echo "ERROR: conda is not installed or not in PATH." >&2
    echo "       L3Rseq requires conda to manage tool environments." >&2
    echo "       Install Miniforge: https://github.com/conda-forge/miniforge" >&2
    exit 1
fi

# ---------------------------------------------------------------------------
# Help text
VERSION="1.0.10"

# ---------------------------------------------------------------------------
show_help() {
    cat <<'HELP'
L3Rseq -- Bioinformatic pipeline for nanopore UMI consensus sequencing

Usage: L3Rseq <subcommand> [options]

Subcommands (preprocessing -- optional):
  concat       Concatenate per-barcode fastq.gz files
  trim         3-pass adapter trimming
  demux        RPI barcode demultiplexing

Subcommand (optional utility):
  filter       Pre-filter reads by rough mapping

Subcommands (core pipeline):
