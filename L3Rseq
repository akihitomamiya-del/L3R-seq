# ---------------------------------------------------------------------------
# Subcommand: umi
# ---------------------------------------------------------------------------
cmd_umi() {
    local input_dir="" output_dir="" probe_file=""
    local method="longread-umi"
    local umi_len="$DEFAULT_UMI_LEN"
    local umi_loc="$DEFAULT_UMI_LOC"
    local min_probe_score="$DEFAULT_MIN_PROBE_SCORE"
    local aln_thresh="$DEFAULT_ALN_THRESH"
    local size_thresh="$DEFAULT_SIZE_THRESH"
    local cluster_steps="$DEFAULT_CLUSTER_STEPS"
    local sample_size="$DEFAULT_SAMPLE_SIZE"
    local umi_flank5="$DEFAULT_UMI_FLANK5"
    local umi_flank3="$DEFAULT_UMI_FLANK3"

    while [ $# -gt 0 ]; do
        case "$1" in
            --input)           require_arg "$1" "${2:-}"; input_dir="$2"; shift 2 ;;
            --outdir)          require_arg "$1" "${2:-}"; output_dir="$2"; shift 2 ;;
            --probe)           require_arg "$1" "${2:-}"; probe_file="$2"; shift 2 ;;
            --method)          require_arg "$1" "${2:-}"; method="$2"; shift 2 ;;
            --umi-len)         require_arg "$1" "${2:-}"; umi_len="$2"; shift 2 ;;
            --umi-loc)         require_arg "$1" "${2:-}"; umi_loc="$2"; shift 2 ;;
            --umi-flank5)      require_arg "$1" "${2:-}"; umi_flank5="$2"; shift 2 ;;
            --umi-flank3)      require_arg "$1" "${2:-}"; umi_flank3="$2"; shift 2 ;;
            --min-probe-score) require_arg "$1" "${2:-}"; min_probe_score="$2"; shift 2 ;;
            --aln-thresh)      require_arg "$1" "${2:-}"; aln_thresh="$2"; shift 2 ;;
            --size-thresh)     require_arg "$1" "${2:-}"; size_thresh="$2"; shift 2 ;;
            --cluster-steps)   require_arg "$1" "${2:-}"; cluster_steps="$2"; shift 2 ;;
            --sample-size)     require_arg "$1" "${2:-}"; sample_size="$2"; shift 2 ;;
            --help)            echo "Usage: L3Rseq umi --input <dir> --outdir <dir> [--probe <file>] [--method umic-seq|longread-umi] [options]"; return 0 ;;
            *)                 echo "Unknown option: $1" >&2; return 1 ;;
        esac
    done

    [ -z "$input_dir" ] && { echo "ERROR: --input is required" >&2; return 1; }
    [ -z "$output_dir" ] && { echo "ERROR: --outdir is required" >&2; return 1; }
    if [ "$method" = "umic-seq" ] && [ -z "$probe_file" ]; then
        echo "ERROR: --probe is required for --method umic-seq" >&2; return 1
    fi

    # Use longread-umi default size threshold if not explicitly overridden
    if [ "$method" = "longread-umi" ] && [ "$size_thresh" = "$DEFAULT_SIZE_THRESH" ]; then
        size_thresh="$DEFAULT_LONGREAD_SIZE_THRESH"
    fi

    source "$SCRIPT_DIR/scripts/04_umi.sh"
    # Activate appropriate conda environment based on method
    if [ "$method" = "longread-umi" ]; then
        conda activate "$ENV_LONGREAD_UMI"
    else
        conda activate "$ENV_UMIC"
    fi
    run_step_04 "$input_dir" "$output_dir" "$probe_file" \
        "$umi_len" "$umi_loc" "$min_probe_score" "$aln_thresh" \
        "$size_thresh" "$cluster_steps" "$sample_size" "$method" \
        "$umi_flank5" "$umi_flank3"
    conda deactivate
}

