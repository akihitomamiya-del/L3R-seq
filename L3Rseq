    local rpi_fasta="" var_file="" prefix=""
    local start_at=1 stop_at=10
    local prefilter=0
    local pattern="$DEFAULT_PATTERN"
    local threads="$DEFAULT_CONSENSUS_THREADS"
    local method="longread-umi"
    local umi_flank5="$DEFAULT_UMI_FLANK5"
    local umi_flank3="$DEFAULT_UMI_FLANK3"
    local count_pattern=""
    local keep_intermediates=0
    # Library-specific overrides (default to config.sh values; for adapter/target
    # customization, edit config.sh or use the individual subcommands directly)
    local blast_db_path="$DEFAULT_BLAST_DB_PATH"
    local blast_db2_path="$DEFAULT_BLAST_DB2_PATH"
    local introns=""
    local target_fwd="$DEFAULT_TARGET_FWD"
    local target_rev="$DEFAULT_TARGET_REV"

    while [ $# -gt 0 ]; do
        case "$1" in
            --input)              require_arg "$1" "${2:-}"; input_dir="$2"; shift 2 ;;
            --outdir)             require_arg "$1" "${2:-}"; output_dir="$2"; shift 2 ;;
            --ref)                require_arg "$1" "${2:-}"; ref_file="$2"; shift 2 ;;
            --probe)              require_arg "$1" "${2:-}"; probe_file="$2"; shift 2 ;;
            --rpi-fasta)          require_arg "$1" "${2:-}"; rpi_fasta="$2"; shift 2 ;;
            --var)                require_arg "$1" "${2:-}"; var_file="$2"; shift 2 ;;
            --pattern)            require_arg "$1" "${2:-}"; pattern="$2"; shift 2 ;;
            --count-pattern)      require_arg "$1" "${2:-}"; count_pattern="$2"; shift 2 ;;
            --prefix)             require_arg "$1" "${2:-}"; prefix="$2"; shift 2 ;;
            --start-at)           require_arg "$1" "${2:-}"; start_at="$2"; shift 2 ;;
            --stop-at)            require_arg "$1" "${2:-}"; stop_at="$2"; shift 2 ;;
            --prefilter)          prefilter=1; shift ;;
            --threads)            require_arg "$1" "${2:-}"; threads="$2"; shift 2 ;;
            --method)             require_arg "$1" "${2:-}"; method="$2"; shift 2 ;;
            --umi-flank5)         require_arg "$1" "${2:-}"; umi_flank5="$2"; shift 2 ;;
            --umi-flank3)         require_arg "$1" "${2:-}"; umi_flank3="$2"; shift 2 ;;
            --blast-db)           require_arg "$1" "${2:-}"; blast_db_path="$2"; shift 2 ;;
            --blast-db2)          require_arg "$1" "${2:-}"; blast_db2_path="$2"; shift 2 ;;
            --introns)            require_arg "$1" "${2:-}"; introns="$2"; shift 2 ;;
            --target-fwd)         require_arg "$1" "${2:-}"; target_fwd="$2"; shift 2 ;;
            --target-rev)         require_arg "$1" "${2:-}"; target_rev="$2"; shift 2 ;;
            --keep-intermediates) keep_intermediates=1; shift ;;
            --help)
                cat <<'RUNHELP'
Usage: L3Rseq run --input <dir> --outdir <dir> [options]

Run the full pipeline (or a subset with --start-at / --stop-at).

Required:
  --input <dir>           Input directory (raw FASTQs or demuxed reads)
  --outdir <dir>          Output directory

Reference & annotation:
  --ref <file>            Reference FASTA (required for steps 07-09)
  --probe <file>          Probe FASTA for UMIC-seq UMI extraction (step 04)
  --rpi-fasta <file>      RPI barcode FASTA for demultiplexing (step 03)
  --var <file>            Variant file for tail correction (auto-detected from step 08)
  --blast-db <path>       BLAST DB prefix for translocation detection (step 09)
  --blast-db2 <path>      BLAST DB prefix for cDNA annotation (step 09)

UMI & editing:
  --method <str>          UMI method: longread-umi (default) or umic-seq
  --pattern <str>         Editing pattern, e.g., CT (default), AG
  --count-pattern <str>   Secondary count-only pattern, e.g., TC for SLAM-seq
  --umi-flank5 <seq>      5' UMI flanking sequence (longread-umi method)
  --umi-flank3 <seq>      3' UMI flanking sequence (longread-umi method)
  --target-fwd <seq>      Forward target sequence for extraction (step 06)
  --target-rev <seq>      Reverse target sequence for extraction (step 06)

Pipeline control:
  --start-at <n>          Start at step n (default: 1)
  --stop-at <n>           Stop after step n (default: 10)
  --threads <n>           Threads for consensus/correction (default: all CPUs)
  --prefilter             Run optional filter step between demux and UMI
  --keep-intermediates    Keep all intermediate files (default: clean up)
  --prefix <str>          Output file prefix for step 01

Adapter/target sequences default to config.sh values. Override per-step
with individual subcommands (L3Rseq trim --adapter-fwd, etc.).
RUNHELP
                return 0 ;;
            *)                    echo "Unknown option: $1" >&2; return 1 ;;
        esac
    done

    [ -z "$input_dir" ] && { echo "ERROR: --input is required" >&2; return 1; }
    [ -z "$output_dir" ] && { echo "ERROR: --outdir is required" >&2; return 1; }
    validate_introns "$introns" || return 1

    mkdir -p "$output_dir"

    # When --start-at > 1, link --input so downstream steps find their data.
    # Two modes: (a) --input contains step output subdirs (e.g., 07_map/, 08_variants/)
    #   → symlink each one; (b) --input IS the data → symlink as the expected dir name.
    if [ "$start_at" -gt 1 ] && [ -n "$input_dir" ]; then
        local _abs_input
        _abs_input="$(cd "$input_dir" && pwd)"

        # Check for numbered step subdirectories inside --input
        local _linked=0
        for _d in "$_abs_input"/[0-9][0-9]_*/; do
            [ -d "$_d" ] || continue
            local _dname
            _dname="$(basename "$_d")"
            if [ ! -e "$output_dir/$_dname" ]; then
                ln -sf "$_abs_input/$_dname" "$output_dir/$_dname"
            fi
            _linked=1
        done

        # No step subdirs found → symlink --input as the expected previous-step output
        if [ "$_linked" -eq 0 ]; then
            local _target
            case "$start_at" in
                2)    _target="01_concat" ;;
                3)    _target="02_trim" ;;
                4)    _target="03_demux" ;;
                5)    _target="04_umi" ;;
                6)    _target="05_consensus" ;;
                7)    _target="06_extract" ;;
                8)    _target="07_map" ;;
                9)    _target="07_map"
                      echo "NOTE: --start-at 9 requires 08_variants/ in --input or --outdir"
                      echo "  for variant auto-detection. Use --var to specify manually."
                      ;;
                10)   _target="09_correct" ;;
            esac
            if [ -n "${_target:-}" ] && [ ! -e "$output_dir/$_target" ]; then
                ln -sf "$_abs_input" "$output_dir/$_target"
            fi
        fi
    fi

    echo "========================================"
    echo "L3Rseq pipeline: steps $start_at to $stop_at"
    echo "========================================"

    # Step 1: Concatenate
    if [ "$start_at" -le 1 ] && [ "$stop_at" -ge 1 ]; then
        source "$SCRIPT_DIR/scripts/01_concat.sh"
        run_step_01 "$input_dir" "$output_dir" "$prefix"
    fi

    # Step 2: Trim (input: 01_concat/)
    if [ "$start_at" -le 2 ] && [ "$stop_at" -ge 2 ]; then
        source "$SCRIPT_DIR/scripts/02_trim.sh"
        conda activate "$ENV_CUTADAPT"
        run_step_02 "$output_dir/01_concat" "$output_dir" \
            "$DEFAULT_ADAPTER_FWD" "$DEFAULT_ADAPTER_REV" "$DEFAULT_ADAPTER_TRIM3" "$DEFAULT_ERROR_RATE"
        conda deactivate
        # Cleanup: trim1/trim2 are intermediate; only trim3 used by step 03
        if [ "$keep_intermediates" -eq 0 ]; then
            for _bc_dir in "$output_dir"/02_trim/*/; do
                [ -d "$_bc_dir" ] || continue
                rm -f "$_bc_dir"/*_trim1.fastq.gz "$_bc_dir"/*_trim2.fastq.gz
            done
        fi
    fi

    # Step 3: Demux (input: 02_trim/)
    if [ "$start_at" -le 3 ] && [ "$stop_at" -ge 3 ]; then
        [ -z "$rpi_fasta" ] && { echo "ERROR: --rpi-fasta is required for step 3" >&2; return 1; }
        [ -n "$rpi_fasta" ] && [ ! -f "$rpi_fasta" ] && { echo "ERROR: --rpi-fasta file not found: $rpi_fasta" >&2; return 1; }
        source "$SCRIPT_DIR/scripts/03_demultiplex.sh"
        conda activate "$ENV_CUTADAPT"
        run_step_03 "$output_dir/02_trim" "$output_dir" "$rpi_fasta" \
            "$DEFAULT_DEMUX_ERROR_RATE" "$DEFAULT_DEMUX_MIN_OVERLAP"
        conda deactivate
        # Cleanup: unclassified reads not used downstream
        if [ "$keep_intermediates" -eq 0 ]; then
            find "$output_dir/03_demux" -name '*_unclassified.fastq' -delete 2>/dev/null || true
        fi
    fi

    # Optional: filter (input: 03_demux/)
    if [ "$prefilter" -eq 1 ] && [ "$start_at" -le 3 ] && [ "$stop_at" -ge 4 ]; then
        [ -z "$ref_file" ] && { echo "ERROR: --ref is required for --prefilter" >&2; return 1; }
        source "$SCRIPT_DIR/scripts/filter.sh"
        conda activate "$ENV_MAP"
        run_step_filter "$output_dir/03_demux" "$output_dir" "$ref_file" "$DEFAULT_MAP_PRESET"
        conda deactivate
    fi

    # Step 4: UMI (input: filter/ or 03_demux/)
    if [ "$start_at" -le 4 ] && [ "$stop_at" -ge 4 ]; then
        if [ "$method" = "umic-seq" ] && [ -z "$probe_file" ]; then
            echo "ERROR: --probe is required for step 4 with --method umic-seq" >&2; return 1
        fi
        local umi_input="$output_dir/03_demux"
        if [ "$prefilter" -eq 1 ] && [ -d "$output_dir/filter" ]; then
            umi_input="$output_dir/filter"
        fi
        local run_size_thresh="$DEFAULT_SIZE_THRESH"
        if [ "$method" = "longread-umi" ]; then
            run_size_thresh="$DEFAULT_LONGREAD_SIZE_THRESH"
        fi
        source "$SCRIPT_DIR/scripts/04_umi.sh"
        if [ "$method" = "longread-umi" ]; then
            conda activate "$ENV_LONGREAD_UMI"
        else
            conda activate "$ENV_UMIC"
        fi
        run_step_04 "$umi_input" "$output_dir" "$probe_file" \
            "$DEFAULT_UMI_LEN" "$DEFAULT_UMI_LOC" "$DEFAULT_MIN_PROBE_SCORE" \
            "$DEFAULT_ALN_THRESH" "$run_size_thresh" "$DEFAULT_CLUSTER_STEPS" \
            "$DEFAULT_SAMPLE_SIZE" "$method" "$umi_flank5" "$umi_flank3"
        conda deactivate
    fi

    # Step 5: Consensus (input: 04_umi/)
    if [ "$start_at" -le 5 ] && [ "$stop_at" -ge 5 ]; then
        source "$SCRIPT_DIR/scripts/05_consensus.sh"
        conda activate "$ENV_LONGREAD_UMI"
        run_step_05 "$output_dir/04_umi" "$output_dir" "$threads" \
            "$DEFAULT_CONSENSUS_ROUNDS" "$DEFAULT_CONSENSUS_PRESET" "$keep_intermediates"
        conda deactivate
        # Cleanup step 04: bin FASTQs and UMI refs no longer needed after consensus
        if [ "$keep_intermediates" -eq 0 ]; then
            for _rpi_dir in "$output_dir"/04_umi/*/*; do
                [ -d "$_rpi_dir" ] || continue
                rm -rf "$_rpi_dir/umi_ref" "$_rpi_dir/trim"
                rm -rf "$_rpi_dir/read_binning/bins" "$_rpi_dir/UMIclusterfull"
            done
        fi
    fi

    # Step 6: Extract (input: 05_consensus/)
    if [ "$start_at" -le 6 ] && [ "$stop_at" -ge 6 ]; then
        source "$SCRIPT_DIR/scripts/06_extract.sh"
        conda activate "$ENV_CUTADAPT"
        run_step_06 "$output_dir/05_consensus" "$output_dir" \
            "$target_fwd" "$target_rev" "$DEFAULT_ERROR_RATE" "$DEFAULT_TARGET_MIN_OVERLAP"
        conda deactivate
    fi

    # Step 7: Map (input: 06_extract/)
    if [ "$start_at" -le 7 ] && [ "$stop_at" -ge 7 ]; then
        [ -z "$ref_file" ] && { echo "ERROR: --ref is required for step 7" >&2; return 1; }
        [ ! -f "$ref_file" ] && { echo "ERROR: --ref file not found: $ref_file" >&2; return 1; }
        source "$SCRIPT_DIR/scripts/07_map.sh"
        conda activate "$ENV_MAP"
        run_step_07 "$output_dir/06_extract" "$output_dir" "$ref_file" "$DEFAULT_MAP_PRESET"
        conda deactivate
        # Cleanup: aligned.sam and aligned.bam redundant with sort.bam
        if [ "$keep_intermediates" -eq 0 ]; then
            for _rpi_dir in "$output_dir"/07_map/*/*; do
                [ -d "$_rpi_dir" ] || continue
                rm -f "$_rpi_dir/aligned.sam" "$_rpi_dir/aligned.bam"
            done
        fi
    fi

    # Step 8: Variants (input: 07_map/)
    if [ "$start_at" -le 8 ] && [ "$stop_at" -ge 8 ]; then
        [ -z "$ref_file" ] && { echo "ERROR: --ref is required for step 8" >&2; return 1; }
        [ ! -f "$ref_file" ] && { echo "ERROR: --ref file not found: $ref_file" >&2; return 1; }
        source "$SCRIPT_DIR/scripts/08_variants.sh"
        conda activate "$ENV_LOFREQ"
        run_step_08 "$output_dir/07_map" "$output_dir" "$ref_file" "$DEFAULT_MIN_AF" "$pattern"
        conda deactivate
    fi

    # Step 9: Correct (input: 07_map/)
    if [ "$start_at" -le 9 ] && [ "$stop_at" -ge 9 ]; then
        [ -z "$ref_file" ] && { echo "ERROR: --ref is required for step 9" >&2; return 1; }
        [ ! -f "$ref_file" ] && { echo "ERROR: --ref file not found: $ref_file" >&2; return 1; }
        # Auto-detect variant files from step 08 if --var not specified
        local run_var_file="$var_file"
        conda activate "$ENV_MAP"
        source "$SCRIPT_DIR/scripts/09_tail_correct.sh"
        run_step_09 "$output_dir/07_map" "$output_dir" "$ref_file" "$run_var_file" "$pattern" \
            "$blast_db_path" "$blast_db2_path" "$DEFAULT_CLIP_THRESH" \
            "$output_dir/08_variants" "$threads" "$count_pattern" "$introns"
        conda deactivate
    fi

    # Step 10: Export (input: 09_correct/)
    if [ "$start_at" -le 10 ] && [ "$stop_at" -ge 10 ]; then
        source "$SCRIPT_DIR/scripts/10_export_csv.sh"
        run_step_10 "$output_dir/09_correct" "$output_dir"
    fi

    echo "========================================"
    echo "L3Rseq pipeline complete."
    echo "========================================"
}

# ---------------------------------------------------------------------------
# Subcommand: viewer
# ---------------------------------------------------------------------------
cmd_viewer() {
    local port=8080
    local stop=0
    local scan_dir=""

    while [ $# -gt 0 ]; do
        case "$1" in
            --port) require_arg "$1" "${2:-}"; port="$2"; shift 2 ;;
            --dir)  require_arg "$1" "${2:-}"; scan_dir="$2"; shift 2 ;;
            --stop) stop=1; shift ;;
            --help) cat <<'VIEWERHELP'
Usage: L3Rseq viewer [--dir <path>] [--port <int>] [--stop]

Start the IGV.js alignment viewer in your browser.
Auto-discovers BAM files from pipeline output directories.

Options:
  --dir <path>   Only scan this directory for datasets (default: entire workspace)
  --port <int>   Port number (default: 8080)
  --stop         Stop a running viewer

Examples:
  L3Rseq viewer                        # scan everything
  L3Rseq viewer --dir tests/output     # only synthetic test results
  L3Rseq viewer --dir runs/Splice      # only one run

The viewer shows:
  - Raw mapping (step 07, gray) and tail-corrected reads (step 09, tan)
  - Reads are displayed in squished mode with soft-clipped bases visible
  - Click any read to see SAM tags (EC, SC, NC, 3E, SJ, etc.)

Requires Node.js. In the devcontainer, the viewer starts automatically.
VIEWERHELP
                return 0 ;;
            *) echo "Unknown option: $1" >&2; return 1 ;;
        esac
    done

    if [ "$stop" -eq 1 ]; then
        if pkill -f "node.*igv_viewer/server.js" 2>/dev/null; then
            echo "Viewer stopped."
        else
            echo "No viewer running."
        fi
        return 0
    fi

    if ! command -v node >/dev/null 2>&1; then
        echo "ERROR: Node.js is not installed. Install it or use the devcontainer." >&2
        return 1
    fi

    # Install dependencies if needed
    if [ ! -d "$SCRIPT_DIR/igv_viewer/node_modules/igv" ]; then
        echo "Installing IGV.js dependency..."
        (cd "$SCRIPT_DIR/igv_viewer" && npm install --silent) || {
            echo "ERROR: npm install failed." >&2; return 1
        }
    fi

    # Resolve --dir to absolute path
    local scan_env=""
    if [ -n "$scan_dir" ]; then
        scan_dir=$(cd "$scan_dir" 2>/dev/null && pwd) || {
            echo "ERROR: --dir not found: $scan_dir" >&2; return 1
        }
        scan_env="$scan_dir"
    fi

    # Stop existing instance if running
    pkill -f "node.*igv_viewer/server.js" 2>/dev/null || true
    sleep 0.5

    IGV_PORT="$port" IGV_SCAN_DIR="$scan_env" IGV_DATA_DIR="${IGV_DATA_DIR:-}" node "$SCRIPT_DIR/igv_viewer/server.js" &
    echo ""
    echo "  IGV.js viewer running at http://localhost:${port}"
    if [ -n "$scan_env" ]; then
        echo "  Scanning: $scan_env"
    fi
    echo "  In VS Code / Codespaces, check the Ports tab to open in browser."
    echo "  Stop with: L3Rseq viewer --stop"
    echo ""
}

# ---------------------------------------------------------------------------
# Main: dispatch subcommand
# ---------------------------------------------------------------------------
if [ $# -eq 0 ]; then
    show_help
    exit 0
fi

subcommand="$1"
shift

case "$subcommand" in
    concat)    cmd_concat "$@" ;;
    trim)      cmd_trim "$@" ;;
    demux)     cmd_demux "$@" ;;
    filter)    cmd_filter "$@" ;;
    umi)       cmd_umi "$@" ;;
    consensus) cmd_consensus "$@" ;;
    extract)   cmd_extract "$@" ;;
    map)       cmd_map "$@" ;;
    variants)  cmd_variants "$@" ;;
    correct)   cmd_correct "$@" ;;
    export)            cmd_export "$@" ;;
    discover-introns)  cmd_discover_introns "$@" ;;
    viewer)            cmd_viewer "$@" ;;
    run)               cmd_run "$@" ;;
    --help|-h)      show_help ;;
    --version|-v)   echo "L3Rseq $VERSION" ;;
    *)              echo "Unknown subcommand: $subcommand" >&2; echo "Run 'L3Rseq --help' for usage." >&2; exit 1 ;;
esac
