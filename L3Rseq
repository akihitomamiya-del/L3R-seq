# Resolve resource paths relative to the script directory
RESOURCES_DIR="$SCRIPT_DIR/resources"
DEFAULT_BLAST_DB_PATH="$RESOURCES_DIR/blast/TAIR10_ChrM/TAIR10_ChrM_db"
