For subcommand-specific help: L3Rseq <subcommand> --help
HELP
}

# ---------------------------------------------------------------------------
# Argument parsing helpers
# ---------------------------------------------------------------------------
require_arg() {
    if [ -z "${2:-}" ] || [[ "${2:-}" == --* ]]; then
        echo "ERROR: $1 requires a value" >&2
        exit 1
    fi
}

# Append a row to the pipeline summary TSV. Creates the file with header if missing.
# Usage: _summary_append <output_dir> <barcode> <rpi> <step> <metric> <value>
_summary_append() {
    local _f="$1/pipeline_summary.tsv"
    if [ ! -f "$_f" ]; then
        printf "timestamp\tbarcode\trpi\tstep\tmetric\tvalue\n" > "$_f"
    fi
    printf "%s\t%s\t%s\t%s\t%s\t%s\n" "$(date +%Y-%m-%dT%H:%M:%S)" "$2" "$3" "$4" "$5" "$6" >> "$_f"
}

# Validate that a conda environment exists before activation.
# Usage: require_conda_env <env_name>
require_conda_env() {
    local env="$1"
    if ! conda env list 2>/dev/null | grep -qE "^${env}\s"; then
        echo "ERROR: conda environment '$env' not found." >&2
        echo "       Required environments are created by the Dockerfile." >&2
        echo "       Run inside the L3Rseq Docker container or create the env manually." >&2
        return 1
    fi
}

# Validate --introns format before passing to step 09.
# Accepts: "start-end", "s1-e1,s2-e2", file.bed, file.gff3, file.gtf
# Returns 0 if valid, 1 with error message if not.
validate_introns() {
    local spec="$1"
    [ -z "$spec" ] && return 0  # empty = no introns, valid

    if [ -f "$spec" ]; then
        local ext="${spec##*.}"
        case "$ext" in
            bed|gff|gff3|gtf)
                # Check file is not empty
                if [ ! -s "$spec" ]; then
                    echo "ERROR: --introns file is empty: $spec" >&2
                    return 1
                fi
                return 0
                ;;
            *)
                echo "ERROR: --introns file has unrecognized extension '.$ext'" >&2
                echo "       Supported formats: .bed, .gff3, .gtf" >&2
                echo "       Or use coordinate format: --introns '500-2100'" >&2
                return 1
                ;;
        esac
    fi

    # Not a file — must be coordinate format (start-end or start-end,start-end)
    if ! echo "$spec" | grep -qE '^[0-9]+-[0-9]+(,[0-9]+-[0-9]+)*$'; then
        echo "ERROR: --introns '$spec' is not a valid format." >&2
        echo "       Expected: coordinate (e.g., '847-2891'), BED file, or GFF3 file." >&2
        echo "       Coordinate format: 'start-end' or 'start-end,start-end'" >&2
        return 1
    fi

    # Validate that start < end for each coordinate
    local IFS=','
    for entry in $spec; do
        local start="${entry%-*}"
        local end="${entry#*-}"
        if [ "$start" -ge "$end" ]; then
            echo "ERROR: --introns '$entry' has start >= end ($start >= $end)" >&2
            return 1
        fi
    done
    return 0
}

# vsearch is always used (usearch support removed).
# These exports are set before longread_umi's dependencies.sh runs so its
# auto-detect doesn't overwrite them.  The USEARCH variable name is kept
# for compatibility with upstream longread_umi scripts that reference it.
_init_vsearch() {
    export USEARCH=vsearch
    export USEARCH_SORTOUT_FLAG="--output"
    export USEARCH_MINSIZE_FLAG=""
    export USEARCH_MINSEQLENGTH_FLAG="--minseqlength 1"
}
_init_vsearch

